{
  "expo": {
    "name": "WILDS",
    "slug": "wilds",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A7C59"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.baptiste.wilds"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#4A7C59"
      },
      "package": "com.baptiste.wilds"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#4A7C59"
        }
      ]
    ],
    "scheme": "wilds",
    "experiments": {
      "typedRoutes": true
    }
  }
}
